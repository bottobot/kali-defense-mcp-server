{
  "name": "kali-defense-mcp-server",
  "version": "0.5.2",
  "description": "Ultimate Kali Defensive Security & System Hardening MCP Server — 78 defensive security tools for firewall management, CIS benchmarks, intrusion detection, malware scanning, container security, zero-trust networking, and more.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "kali-defense-mcp": "build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/TOOLS-REFERENCE.md",
    "docs/SAFEGUARDS.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:verify": "tsc --noEmit",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:security": "eslint src/ --max-warnings=0",
    "audit:security": "npm audit --audit-level=high",
    "changelog:check": "git diff HEAD~1 --name-only | grep -q CHANGELOG.md || echo 'Warning: CHANGELOG.md not updated'",
    "license:check": "license-checker --production --failOn 'GPL-3.0;AGPL-3.0'",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "kali",
    "security",
    "hardening",
    "defensive-security",
    "firewall",
    "iptables",
    "ufw",
    "cis-benchmark",
    "intrusion-detection",
    "malware-scanning",
    "container-security",
    "compliance",
    "sysctl",
    "fail2ban",
    "apparmor",
    "selinux",
    "zero-trust",
    "wireguard",
    "incident-response"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bottobot/kali-defense-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/bottobot/kali-defense-mcp-server/issues"
  },
  "homepage": "https://github.com/bottobot/kali-defense-mcp-server#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.4",
    "@types/node": "~22.19.11",
    "@vitest/coverage-v8": "~4.0.18",
    "eslint": "~9.39.4",
    "eslint-plugin-security": "~3.0.1",
    "husky": "~9.1.7",
    "license-checker": "~25.0.1",
    "tsx": "~4.21.0",
    "typescript": "~5.9.3",
    "vitest": "~4.0.18"
  }
}
